# Copy to apps/web/.env.local for Next.js.

# Proof-of-concept (default): omit or leave unset — UI uses in-memory mock data (no Docker/Supabase required).
# Set to false when wiring production auth + database + API routes.
NEXT_PUBLIC_POC_MODE=

# Supabase — project URL + anon key (browser-safe)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never expose to client
SUPABASE_SERVICE_ROLE_KEY=

# Optional shared fallback for Places/Sheets stubs when user key not set
GOOGLE_API_KEY=

# Email — configure in Supabase Dashboard (Auth → SMTP) for magic links
EMAIL_FROM=noreply@leadphantom.local

# Site URL used in magic-link redirects (production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
