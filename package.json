{
  "name": "lead-phantom",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "lint": "eslint \"packages/**/*.ts\" && pnpm --filter web lint",
    "typecheck": "pnpm --filter @lead-phantom/shared typecheck && pnpm --filter @lead-phantom/services typecheck && pnpm --filter web typecheck",
    "test": "pnpm --filter @lead-phantom/services test",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.12.0",
    "prettier": "^3.4.1",
    "typescript-eslint": "^8.16.0"
  },
  "packageManager": "pnpm@9.14.4",
  "engines": {
    "node": ">=18"
  }
}
